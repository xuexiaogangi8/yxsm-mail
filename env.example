# Temp-Mail 环境变量示例
# 复制本文件为 .dev.vars（本地开发）或在 GitHub Secrets / Cloudflare 中配置对应变量。
# 不要提交包含真实值的 .dev.vars 或 .env 到版本库。

# ========== 部署用（CI / 本地 wrangler） ==========
# D1_DATABASE_ID=          # D1 数据库 ID，wrangler.toml 中会引用
# CLOUDFLARE_ACCOUNT_ID=  # Cloudflare 账户 ID（GitHub Actions 等）
# CLOUDFLARE_API_TOKEN=   # Cloudflare API Token（需 Workers + D1 等权限）

# ========== Worker 运行时必需 ==========
# MAIL_DOMAIN=            # 临时邮箱域名，多个用逗号或空格分隔，如 example.com,mail.example.com
# JWT_SECRET=             # 登录会话签名密钥（必填）

# ========== Worker 运行时强烈推荐 ==========
# ADMIN_PASSWORD=         # 管理后台严格管理员密码

# ========== Worker 运行时可选 ==========
# ADMIN_NAME=admin        # 管理员用户名，默认 admin
# JWT_TOKEN=              # 根管理员令牌（Bearer / X-Admin-Token），用于脚本或调试
# GUEST_ENABLED=          # 是否开启访客入口，如 true
# GUEST_PASSWORD=         # 访客账号密码
# SITE_MODE=selfhost      # demo | selfhost，控制登录页与横幅提示
# CACHE_TTL=              # 缓存 TTL（秒），降低 D1 访问频率
# EMAIL_RETENTION_DAYS=60 # 全局默认邮件保留天数
# MAIL_LOCALPART_MIN_LEN= # 随机邮箱前缀最小长度
# MAIL_LOCALPART_MAX_LEN= # 随机邮箱前缀最大长度

# ========== 发件（Resend） ==========
# RESEND_API_KEY=         # 或 RESEND_TOKEN / RESEND，开启发件箱功能

# ========== Telegram Bot ==========
# TELEGRAM_BOT_TOKEN=     # Bot 令牌
# TELEGRAM_CHAT_ID=       # 默认接收通知的会话 ID

# ========== 其他可选 ==========
# FORWARD_RULES=          # 邮件转发规则（JSON）
# MAX_EMAIL_SIZE=         # 单封邮件最大尺寸（预留）
